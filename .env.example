# Copy this file to .env.local for local development.
# Never commit real secrets — .env.local is in .gitignore.

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — SQLite by default for local dev; set DATABASE_URL for Postgres.
# DATABASE_URL=postgres://user:pass@localhost:5432/poker_schedule

# Email (production uses SMTP; local dev logs to console)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Railway auto-injects RAILWAY_PUBLIC_DOMAIN in prod — no need to set it here.
